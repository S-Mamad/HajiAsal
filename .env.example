# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://hajiasal.ir

# MySQL (REQUIRED for production on host)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=your_db_name
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# Admin panel (/admin)
ADMIN_PASSWORD=change_me_strong_password

# Customer auth (required in production)
AUTH_SESSION_SECRET=change_me_long_random_secret_min_32_chars

# Test OTP — development ONLY (never enable in production)
AUTH_TEST_PHONE=09123456789
AUTH_TEST_OTP=1234

# SMS — Melipayamak Console OTP
# Docs: POST { "to": "09xxxxxxxxx" } → { "code": "...", "status": "..." }
# Put the full OTP endpoint from Melipayamak console (or only the token via MELIPAYAMAK_OTP_TOKEN).
SMS_PROVIDER=melipayamak
MELIPAYAMAK_OTP_URL=https://console.melipayamak.com/api/send/otp/YOUR_TOKEN_HERE
# MELIPAYAMAK_OTP_TOKEN=YOUR_TOKEN_HERE

# Payment (optional)
ZARINPAL_MERCHANT_ID=

# Seller panel
SELLER_DEMO_PASSWORD=seller123
# SELLER_PASSWORD_S1=
# SELLER_PASSWORD_S2=

# TRUST_X_FORWARDED_FOR=true

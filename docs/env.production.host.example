NODE_ENV=production
PORT=3000

# دامنه رسمی (بدون اسلش آخر)
NEXT_PUBLIC_SITE_URL=https://hajiasal.ir

# <<< MySQL هاست / cPanel >>>
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=YOUR_DB_NAME
MYSQL_USER=YOUR_DB_USER
MYSQL_PASSWORD=YOUR_DB_PASSWORD

# پنل ادمین
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# نشست مشتری (حداقل ۳۲ کاراکتر تصادفی)
AUTH_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_32_CHARS

# فروشنده 1 و 2
SELLER_PASSWORD_S1=CHANGE_ME_SELLER_1
SELLER_PASSWORD_S2=CHANGE_ME_SELLER_2

# SMS ملی‌پیامک — Console OTP
# POST JSON: { "to": "09123456789" }
# Response: { "code": "....", "status": "..." }
# کد برگشتی را سرور ذخیره می‌کند و کاربر همان را وارد می‌کند.
SMS_PROVIDER=melipayamak
MELIPAYAMAK_OTP_URL=https://console.melipayamak.com/api/send/otp/YOUR_TOKEN_HERE

# اختیاری: درگاه زرین‌پال
ZARINPAL_MERCHANT_ID=

# پشت پروکسی هاست
TRUST_X_FORWARDED_FOR=true
